{
  "sourcePdf": "https://army-forge.onepagerules.com/army-info/age-of-fantasy/RJDq2ZD7wjlAcUVB?armyName=Dwarves",
  "sourceUrl": "https://army-forge.onepagerules.com/army-info/age-of-fantasy/RJDq2ZD7wjlAcUVB?armyName=Dwarves",
