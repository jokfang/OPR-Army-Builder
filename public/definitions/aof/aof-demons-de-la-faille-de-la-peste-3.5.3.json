{
  "sourcePdf": "https://army-forge.onepagerules.com/army-info/age-of-fantasy/vJuokTQpJWj3_MrJ?armyName=Daemons+of+Plague",
  "sourceUrl": "https://army-forge.onepagerules.com/army-info/age-of-fantasy/vJuokTQpJWj3_MrJ?armyName=Daemons+of+Plague",
